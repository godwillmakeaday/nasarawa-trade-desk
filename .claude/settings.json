{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run typecheck)",
      "Bash(npm run db:generate)",
      "Bash(npm run db:studio)",
      "Bash(npm install)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prisma generate)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)"
    ]
  }
}
