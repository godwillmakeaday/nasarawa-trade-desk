generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROCUREMENT_OFFICER
  LOGISTICS_OFFICER
  FINANCE_OFFICER
  DISPUTE_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  SOURCING
  QUOTED
  AWAITING_PAYMENT
  PROCUREMENT_STARTED
  QUALITY_CHECK
  READY_FOR_DISPATCH
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CHARGEBACK
}

enum ShipmentStatus {
  NOT_READY
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  AT_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WAITING_ON_CUSTOMER
  WAITING_ON_VENDOR
  RESOLVED
  ESCALATED
  CLOSED
}

enum EvidenceType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEXT_NOTE
}

enum TransportAssignmentStatus {
  PENDING
  ASSIGNED
  RELEASED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  EXCEPTION
}

enum CommunicationStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  AWAITING_RESPONSE
}

enum EscalationLevel {
  L1
  L2
  L3
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  PAYMENT_CAPTURE
  STATUS_CHANGE
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  phone              String?
  passwordHash       String
  role               UserRole            @default(CUSTOMER)
  status             AccountStatus       @default(PENDING_VERIFICATION)
  organizationId     String?
  organization       Organization?       @relation(fields: [organizationId], references: [id])
  officerProfile     ProcurementOfficerProfile?
  procurementRequests ProcurementRequest[] @relation("CustomerRequests")
  assignedTasks      ProcurementTask[]   @relation("AssignedOfficer")
  transportAssignments TransportAssignment[] @relation("TransportAssignedBy")
  podUploads         ProofOfDelivery[]    @relation("PodUploadedBy")
  communications     WhatsAppCommunication[] @relation("CommunicationActor")
  disputeEscalations DisputeEscalation[]  @relation("EscalationActor")
  disputesOpened     Dispute[]           @relation("DisputeReporter")
  auditTrails        AuditTrail[]
  transactionLogs    TransactionLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([role])
  @@index([organizationId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  rcNumber  String?
  address   String?
  state     String?
  lga       String?
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProcurementRequest {
  id              String                  @id @default(cuid())
  requestNumber   String                  @unique
  customerId      String
  customer        User                    @relation("CustomerRequests", fields: [customerId], references: [id])
  title           String
  description     String
  marketState     String                  @default("Nasarawa")
  targetMarkets   String[]
  deliveryAddress String
  deliveryState   String
  deliveryLga     String?
  budgetMin       Decimal?                @db.Decimal(12, 2)
  budgetMax       Decimal?                @db.Decimal(12, 2)
  status          RequestStatus           @default(SUBMITTED)
  priority        Int                     @default(2)
  images          ProductReferenceImage[]
  quotations      Quotation[]
  order           Order?
  tasks           ProcurementTask[]
  inspectionEvidence InspectionEvidenceItem[]
  disputes        Dispute[]
  auditTrails     AuditTrail[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([customerId, status])
  @@index([requestNumber])
}

model ProductReferenceImage {
  id                   String             @id @default(cuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  url                  String
  fileName             String
  contentType          String
  sizeBytes            Int
  createdAt            DateTime           @default(now())
}

model Quotation {
  id                   String             @id @default(cuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  subtotal             Decimal            @db.Decimal(12, 2)
  serviceFee           Decimal            @db.Decimal(12, 2)
  logisticsFee         Decimal            @db.Decimal(12, 2)
  tax                  Decimal            @default(0) @db.Decimal(12, 2)
  total                Decimal            @db.Decimal(12, 2)
  currency             String             @default("NGN")
  validUntil           DateTime
  notes                String?
  acceptedAt           DateTime?
  rejectedAt           DateTime?
  order                Order?
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Order {
  id                   String             @id @default(cuid())
  orderNumber          String             @unique
  procurementRequestId String             @unique
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id])
  quotationId          String             @unique
  quotation            Quotation          @relation(fields: [quotationId], references: [id])
  status               RequestStatus      @default(AWAITING_PAYMENT)
  payment              Payment?
  shipment             Shipment?
  transportAssignments TransportAssignment[]
  proofOfDeliveries    ProofOfDelivery[]
  communications       WhatsAppCommunication[]
  transactions         TransactionLog[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([orderNumber])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  orderId          String        @unique
  order            Order         @relation(fields: [orderId], references: [id])
  provider         String        @default("paystack")
  providerRef      String        @unique
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("NGN")
  status           PaymentStatus @default(INITIATED)
  paidAt           DateTime?
  rawProviderEvent Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model ProcurementTask {
  id                   String             @id @default(cuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  title                String
  marketName           String
  assignedOfficerId    String?
  assignedOfficer      User?              @relation("AssignedOfficer", fields: [assignedOfficerId], references: [id])
  status               RequestStatus      @default(SOURCING)
  notes                String?
  dueAt                DateTime?
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([assignedOfficerId, status])
}

model Shipment {
  id              String          @id @default(cuid())
  orderId          String          @unique
  order            Order           @relation(fields: [orderId], references: [id])
  carrierName      String
  carrierPhone     String?
  trackingCode     String          @unique
  pickupMarket     String
  destinationState String
  destinationLga   String?
  status           ShipmentStatus  @default(SCHEDULED)
  eta              DateTime?
  deliveredAt      DateTime?
  events           TrackingEvent[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([trackingCode])
  @@index([status])
}

model ProcurementOfficerProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketName       String
  lga              String
  phone            String
  languages        String[]
  specialties      String[]
  verificationNote String
  supervisorName   String
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([marketName])
}

model InspectionEvidenceItem {
  id                   String             @id @default(cuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  type                 EvidenceType
  title                String
  description          String?
  url                  String?
  status               String             @default("PENDING_REVIEW")
  reviewerName         String?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([procurementRequestId])
  @@index([type, status])
}

model TransportAssignment {
  id             String                    @id @default(cuid())
  orderId        String
  order          Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedById   String?
  assignedBy     User?                     @relation("TransportAssignedBy", fields: [assignedById], references: [id])
  carrierName    String
  driverName     String
  driverPhone    String
  vehiclePlate   String
  vehicleType    String?
  lane           String
  routeRisk      String                    @default("WATCH")
  manifest       String
  status         TransportAssignmentStatus @default(PENDING)
  releaseGate    String?
  assignedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([orderId])
  @@index([status])
}

model ProofOfDelivery {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedById  String?
  uploadedBy    User?    @relation("PodUploadedBy", fields: [uploadedById], references: [id])
  recipientName String
  recipientPhone String?
  destination   String
  evidenceUrls  String[]
  signedBy      String?
  locationNote  String?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
}

model TrackingEvent {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      ShipmentStatus
  location    String
  description String
  occurredAt  DateTime       @default(now())
  createdAt   DateTime       @default(now())

  @@index([shipmentId, occurredAt])
}

model WhatsAppCommunication {
  id           String              @id @default(cuid())
  orderId      String?
  order        Order?              @relation(fields: [orderId], references: [id])
  actorId      String?
  actor        User?               @relation("CommunicationActor", fields: [actorId], references: [id])
  phone        String
  templateName String
  message      String
  linkedRecord String?
  providerRef  String?
  status       CommunicationStatus @default(DRAFT)
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([orderId])
  @@index([phone])
  @@index([status])
}

model Dispute {
  id                   String             @id @default(cuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id])
  reporterId           String
  reporter             User               @relation("DisputeReporter", fields: [reporterId], references: [id])
  status               DisputeStatus      @default(OPEN)
  reason               String
  description          String
  resolution           String?
  escalations          DisputeEscalation[]
  resolvedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
}

model DisputeEscalation {
  id          String          @id @default(cuid())
  disputeId   String
  dispute     Dispute         @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?           @relation("EscalationActor", fields: [actorId], references: [id])
  level       EscalationLevel
  trigger     String
  sla         String
  action      String
  status      DisputeStatus   @default(UNDER_REVIEW)
  createdAt   DateTime        @default(now())
  resolvedAt  DateTime?

  @@index([disputeId])
  @@index([level, status])
}

model TransactionLog {
  id          String   @id @default(cuid())
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  eventType   String
  amount      Decimal? @db.Decimal(12, 2)
  currency    String   @default("NGN")
  providerRef String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([actorId])
  @@index([eventType])
}

model AuditTrail {
  id                   String              @id @default(cuid())
  actorId              String?
  actor                User?               @relation(fields: [actorId], references: [id])
  procurementRequestId String?
  procurementRequest   ProcurementRequest? @relation(fields: [procurementRequestId], references: [id])
  action               AuditAction
  entityType           String
  entityId             String
  before               Json?
  after                Json?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime            @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
